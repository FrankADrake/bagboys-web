---
import Layout from '../../layouts/Layout.astro';

/**
 * The Burren — /history/burren
 *
 * Text content from SPEC §4.13 (already largely past tense).
 *
 * Photos go in public/images/burren/
 * Drop any .jpg, .jpeg, .png, or .webp files there and they
 * appear automatically — no code changes needed.
 */

const rawPaths = Object.keys(
  import.meta.glob('/public/images/burren/*.{jpg,jpeg,png,webp}')
);
const photos = rawPaths.map((p) => p.replace('/public', ''));
---

<Layout title="The Burren — The Bagboys">
  <div class="page-body">

    <h1 class="page-heading">The Burren</h1>
    <p class="venue-address">247 Elm St, Somerville, MA</p>

    <section class="venue-text">
      <p class="para-history">
        Deeply committed to music, the Burren hosted bands every day of the week.
        The Bagboys had a residency there on Saturday evenings from 2006–2018.
        We even toured the west coast of Ireland under their sponsorship, and got
        to visit the actual Burren!
      </p>
    </section>

    {photos.length > 0 ? (
      <section class="photo-section">
        <div class="photo-grid">
          {photos.map((src) => (
            <div class="photo-wrap">
              <img src={src} alt="The Bagboys at the Burren" loading="lazy" />
            </div>
          ))}
        </div>
      </section>
    ) : (
      <p class="photos-pending">[ Photos coming soon ]</p>
    )}

    <p class="back-link"><a href="/history/residencies">← Back to Residencies</a></p>

  </div>
</Layout>

<style>
  .venue-address {
    text-align: center;
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 2rem;
  }

  .venue-text {
    max-width: 680px;
    margin: 0 auto 2.5rem;
  }

  .para-history {
    font-size: 1.05rem;
    color: #444;
    line-height: 1.75;
    text-align: center;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }

  .photo-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: 3px;
    background: #c8bfa8;
  }

  .photo-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .photo-wrap:hover img {
    transform: scale(1.04);
  }

  .photos-pending {
    text-align: center;
    font-size: 0.9rem;
    color: #aaa;
    font-style: italic;
    padding: 2rem 0;
  }

  .back-link {
    font-size: 0.9rem;
  }
</style>
