---
import Layout from '../../layouts/Layout.astro';

/**
 * Historical Posters — /history/posters
 *
 * Slideshow: one poster at a time, prev/next buttons, thumbnail strip.
 *
 * Photos go in public/images/posters/
 * Drop any .jpg, .jpeg, .png, or .webp files there and they
 * appear automatically — no code changes needed.
 *
 * Page heading uses dark red + Open Sans (not teal Pacifico) per SPEC §4.15.
 */

const rawPaths = Object.keys(
  import.meta.glob('/public/images/posters/*.{jpg,jpeg,png,webp}')
);
const photos = rawPaths.map((p) => p.replace('/public', '')).sort();
const hasPhotos = photos.length > 0;
---

<Layout title="Historical Posters — The Bagboys">
  <div class="page-body">

    <h1 class="page-heading-red">Various Posters</h1>

    {hasPhotos ? (
      <!-- ===================================================
           SLIDESHOW
           One poster displayed large; prev/next buttons;
           thumbnail strip below. All driven by client-side JS.
           =================================================== -->
      <div class="slideshow" id="slideshow">

        <div class="slide-stage">
          <button class="slide-btn slide-prev" id="slide-prev" aria-label="Previous poster">&#8592;</button>
          <div class="slide-frame">
            <img id="slide-img" src={photos[0]} alt="Bagboys poster" />
          </div>
          <button class="slide-btn slide-next" id="slide-next" aria-label="Next poster">&#8594;</button>
        </div>

        <p class="slide-counter">
          <span id="slide-current">1</span> / <span id="slide-total">{photos.length}</span>
        </p>

        <div class="thumb-strip" id="thumb-strip">
          {photos.map((src, i) => (
            <button
              class:list={['thumb-btn', { active: i === 0 }]}
              data-index={i}
              aria-label={`Go to poster ${i + 1}`}
            >
              <img src={src} alt={`Poster ${i + 1}`} loading="lazy" />
            </button>
          ))}
        </div>

      </div>
    ) : (
      <p class="photos-pending">NOTE: Posters needed — drop images into public/images/posters/ to populate this slideshow.</p>
    )}

    <p class="back-link"><a href="/history">← Back to History</a></p>

  </div>
</Layout>

{hasPhotos && (
  <script define:vars={{ photos }}>
    let current = 0;

    const img       = document.getElementById('slide-img');
    const counter   = document.getElementById('slide-current');
    const prevBtn   = document.getElementById('slide-prev');
    const nextBtn   = document.getElementById('slide-next');
    const thumbStrip = document.getElementById('thumb-strip');
    const thumbBtns = thumbStrip ? Array.from(thumbStrip.querySelectorAll('.thumb-btn')) : [];

    function goTo(index) {
      // Wrap around
      current = (index + photos.length) % photos.length;

      img.src = photos[current];
      img.alt = `Bagboys poster ${current + 1}`;
      counter.textContent = current + 1;

      // Update active thumbnail
      thumbBtns.forEach((btn, i) => {
        btn.classList.toggle('active', i === current);
      });

      // Scroll the active thumbnail into view
      if (thumbBtns[current]) {
        thumbBtns[current].scrollIntoView({ block: 'nearest', inline: 'center', behavior: 'smooth' });
      }
    }

    prevBtn.addEventListener('click', () => goTo(current - 1));
    nextBtn.addEventListener('click', () => goTo(current + 1));

    thumbBtns.forEach((btn) => {
      btn.addEventListener('click', () => goTo(Number(btn.dataset.index)));
    });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft')  goTo(current - 1);
      if (e.key === 'ArrowRight') goTo(current + 1);
    });
  </script>
)}

<style>
  /* ---- Page heading — dark red, Open Sans ------------ */
  .page-heading-red {
    font-family: 'Open Sans', sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: var(--dark-red);
    text-align: center;
    margin: 1.5rem 0 2rem;
  }

  /* ---- Slideshow ------------------------------------- */
  .slideshow {
    max-width: 680px;
    margin: 0 auto 2rem;
  }

  /* Stage: prev button | poster | next button */
  .slide-stage {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .slide-frame {
    flex: 1;
    background: #111;
    border: 4px solid #fff;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.25);
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 420px;
  }

  .slide-frame img {
    max-width: 100%;
    max-height: 560px;
    object-fit: contain;
    display: block;
  }

  .slide-btn {
    background: var(--teal);
    color: #fff;
    border: none;
    border-radius: 3px;
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1.2rem;
    cursor: pointer;
    flex-shrink: 0;
    transition: background-color 0.15s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .slide-btn:hover {
    background: #2e8e89;
  }

  /* Counter: "3 / 16" */
  .slide-counter {
    text-align: center;
    font-size: 0.85rem;
    color: #888;
    margin-bottom: 1rem;
  }

  /* ---- Thumbnail strip ------------------------------- */
  .thumb-strip {
    display: flex;
    gap: 0.4rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: thin;
  }

  .thumb-btn {
    flex-shrink: 0;
    width: 64px;
    height: 80px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 2px;
    background: #111;
    cursor: pointer;
    overflow: hidden;
    transition: border-color 0.15s ease;
    opacity: 0.6;
  }

  .thumb-btn:hover {
    opacity: 1;
  }

  .thumb-btn.active {
    border-color: var(--teal);
    opacity: 1;
  }

  .thumb-btn img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---- Pending placeholder --------------------------- */
  .photos-pending {
    text-align: center;
    font-size: 0.9rem;
    color: #c00;
    font-style: italic;
    padding: 1.5rem;
    border: 2px dashed #c00;
    border-radius: 4px;
  }

  /* ---- Back link ------------------------------------- */
  .back-link {
    font-size: 0.9rem;
    margin-top: 1rem;
  }
</style>
